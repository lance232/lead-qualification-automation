    {
      "parameters": {
        "sendTo": "laverus05@gmail.com",
        "subject": "=New Qualified Lead | {{ $('Normalize Lead Data').item.json.Company }} | Score: {{ $json[\"Lead Score\"] }}/100",
        "emailType": "text",
        "message": "=Hello Sales Team,\n\nA new lead has been successfully qualified and requires sales follow-up.\n\n────────────────────────────────\nLEAD INFORMATION\n────────────────────────────────\n\nName: {{ $('Normalize Lead Data').item.json.Name }}\n\nCompany: {{ $('Normalize Lead Data').item.json.Company }}\n\nJob Title: {{ $('Normalize Lead Data').item.json[\"Job Title\"] }}\n\nIndustry: {{ $('Normalize Lead Data').item.json.Industry }}\n\nCompany Size: {{ $('Normalize Lead Data').item.json[\"Company Size\"] }}\n\nBudget: {{ $('Normalize Lead Data').item.json.Budget }}\n\n────────────────────────────────\nLEAD ASSESSMENT\n────────────────────────────────\n\nLead Score: {{ $json[\"Lead Score\"] }}/100\n\nPriority: {{ $json.Priority }}\n\nRecommended Action: {{ $json.Action }}\n\nSummary:\n{{ $json.Summary }}\n\n────────────────────────────────\nNEXT STEPS\n────────────────────────────────\n\nThis lead has been classified as a high-priority opportunity based on the information submitted. Please review the lead details and initiate follow-up at your earliest convenience.\n\nThank you,\n\nLead Qualification System\n",
        "options": {}
